<Window x:Class="Hps.Sample.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HPS Interface Server Dashboard"
        Width="1180"
        Height="760"
        MinWidth="960"
        MinHeight="620"
        Background="#F6F7F9"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9DEE7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="#12324A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#12324A" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="HPS Interface Server"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#14212B" />
                <TextBlock Text="TCP/UDP publish-subscribe smoke와 transport diagnostics"
                           Margin="0,3,0,0"
                           Foreground="#5D6978" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource CommandButton}" Content="Start server" Command="{Binding StartServerCommand}" />
                <Button Style="{StaticResource CommandButton}" Content="Stop server" Command="{Binding StopServerCommand}" />
                <Button Style="{StaticResource CommandButton}" Content="TCP smoke" Command="{Binding RunTcpSmokeCommand}" />
                <Button Style="{StaticResource CommandButton}" Content="UDP smoke" Command="{Binding RunUdpSmokeCommand}" Margin="0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Server" Foreground="#5D6978" />
                    <TextBlock Text="{Binding ServerStatusText}" Margin="0,8,0,0" FontSize="20" FontWeight="SemiBold" Foreground="#12324A" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="TCP" Foreground="#5D6978" />
                    <TextBlock Text="{Binding LastSmokeSummary}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#14212B" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="UDP" Foreground="#5D6978" />
                    <TextBlock Text="{Binding LastSmokeSummary}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#14212B" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="io_uring evidence" Foreground="#5D6978" />
                    <TextBlock Text="{Binding IoUringStatusText}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#14212B" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Diagnostics" FontSize="16" FontWeight="SemiBold" Foreground="#14212B" />
                    <DataGrid Grid.Row="1"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              ItemsSource="{Binding Metrics}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Pending" Binding="{Binding PendingSendCount}" Width="*" />
                            <DataGridTextColumn Header="HWM" Binding="{Binding PendingSendQueueHighWatermark}" Width="*" />
                            <DataGridTextColumn Header="Dropped" Binding="{Binding DroppedPendingSendCount}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Run log" FontSize="16" FontWeight="SemiBold" Foreground="#14212B" />
                    <ListBox Grid.Row="1"
                             Margin="0,12,0,0"
                             ItemsSource="{Binding LogEntries}"
                             BorderBrush="#D9DEE7" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
